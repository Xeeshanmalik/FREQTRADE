{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "max_open_trades": 1,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.95,
  "dry_run": true,
  "dry_run_wallet": 1000,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "unfilledtimeout": {
    "entry": 5,
    "exit": 10,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "binance",
    "pair_whitelist": [
      "ADA/USDT:USDT",
      "AVAX/USDT:USDT",
      "BCH/USDT:USDT",
      "BTC/USDT:USDT",
      "DOGE/USDT:USDT",
      "ENA/USDT:USDT",
      "ETH/USDT:USDT",
      "FET/USDT:USDT",
      "ICP/USDT:USDT",
      "INJ/USDT:USDT",
      "LINK/USDT:USDT",
      "LTC/USDT:USDT",
      "MEME/USDT:USDT",
      "NEAR/USDT:USDT",
      "ONDO/USDT:USDT",
      "RENDER/USDT:USDT",
      "SOL/USDT:USDT",
      "SUI/USDT:USDT",
      "TAO/USDT:USDT",
      "TON/USDT:USDT",
      "TRX/USDT:USDT",
      "XLM/USDT:USDT",
      "XRP/USDT:USDT",
      "ZEC/USDT:USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "bot_name": "shortprecision-bt",
  "initial_state": "running",
  "internals": {
    "process_throttle_secs": 5
  }
}